generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  image     String?
  provider  Provider

  notes     Note[]

  createdAt DateTime @default(now())
}

model Note {
  id          String   @id @default(uuid())
  title       String
  fileUrl     String

  branch      String   @default("CSE")
  year        Int
  semester    String   // "odd" or "even"
  subject     String

  category    NoteCategory @default(DIGITAL)

  uploadedBy  String
  user        User     @relation(fields: [uploadedBy], references: [id])

  createdAt   DateTime @default(now())
}

enum Provider {
  Google
}

enum NoteCategory {
  HANDWRITTEN
  DIGITAL
  PYQ
}